[Unit]
Description=Model Training Scheduler
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/forecast-vibecoding
Environment=PATH=/home/ubuntu/forecast-vibecoding/venv/bin
ExecStart=/home/ubuntu/forecast-vibecoding/venv/bin/python scheduler_daemon.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target